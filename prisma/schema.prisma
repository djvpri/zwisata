generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          String    @default("USER")
  accounts      Account[]
  sessions      Session[]
  pesanan       Pesanan[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Wahana {
  id           String   @id @default(cuid())
  nama         String
  slug         String   @unique
  deskripsi    String?  @db.Text
  kapasitas    Int
  tinggiMin    Int?
  durasiMenit  Int      @default(5)
  status       String   @default("AKTIF")
  icon         String   @default("star")
  warna        String   @default("#3b82f6")
  hargaTiket   Int?
  tiket        Tiket[]
  antrian      Antrian[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tiket {
  id          String   @id @default(cuid())
  nama        String
  slug        String   @unique
  deskripsi   String?  @db.Text
  tipe        String   @default("MASUK")
  harga       Int?
  wahanaId    String?
  wahana      Wahana?  @relation(fields: [wahanaId], references: [id])
  kuotaHarian Int?
  pesananItem PesananItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pesanan {
  id              String   @id @default(cuid())
  kode            String   @unique
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  namaPemesan     String
  emailPemesan    String
  noHpPemesan     String
  tglKunjungan    DateTime
  total           Int
  status          String   @default("MENUNGGU")
  items           PesananItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PesananItem {
  id        String   @id @default(cuid())
  pesananId String
  pesanan   Pesanan  @relation(fields: [pesananId], references: [id], onDelete: Cascade)
  tiketId   String
  tiket     Tiket    @relation(fields: [tiketId], references: [id])
  qty       Int
  harga     Int
  subtotal  Int
}

model Antrian {
  id             String   @id @default(cuid())
  wahanaId       String
  wahana         Wahana   @relation(fields: [wahanaId], references: [id], onDelete: Cascade)
  noAntrian      Int
  namaPengunjung String
  status         String   @default("MENUNGGU")
  estimasi       Int      @default(10)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([wahanaId, noAntrian])
}

model Staff {
  id        String   @id @default(cuid())
  nama      String
  nip       String?  @unique
  noHp      String?
  posisi    String   @default("OPERATOR")
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}